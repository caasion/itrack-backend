# Copy this to .env and fill in real values
# Never commit .env to git

GEMINI_API_KEY=your_gemini_api_key_here
BACKBOARD_API_KEY=your_backboard_api_key_here
BACKBOARD_BASE_URL=https://api.backboard.io

# Product sourcing toggle: "serpapi" or "hardcoded"
PRODUCT_SOURCING_MODE=hardcoded
SERPAPI_KEY=your_serpapi_key_here

# Cloudinary — set CLOUDINARY_ENABLED=true when ready to test transforms
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

DEBUG=true
